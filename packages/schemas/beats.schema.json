{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "beats.schema.json",
  "title": "EpisodeBeats",
  "type": "object",
  "required": ["schema_version", "episode", "beats"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },

    "episode": {
      "type": "object",
      "required": ["episode_id", "bible_ref", "topic", "target_duration_sec"],
      "properties": {
        "episode_id": { "type": "string" },
        "bible_ref": { "type": "string" },
        "topic": { "type": "string" },
        "target_duration_sec": { "type": "integer", "default": 600 },
        "profiles": {
          "type": "object",
          "required": ["studio_profile_id", "channel_profile_id", "mascot_profile_id"],
          "properties": {
            "studio_profile_id": { "type": "string" },
            "channel_profile_id": { "type": "string" },
            "mascot_profile_id": { "type": "string" }
          }
        },
        "data_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dataset_id"],
            "properties": {
              "dataset_id": { "type": "string" },
              "time_range": { "type": "string" }
            }
          }
        }
      }
    },

    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat_id", "kind", "narration"],
        "properties": {
          "beat_id": { "type": "string" },
          "kind": { "type": "string" },
          "intent": { "type": "string" },
          "narration": { "type": "string" },

          "on_screen_text": { "type": "array", "items": { "type": "string" } },

          "data_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["dataset_id", "ref_id"],
              "properties": {
                "dataset_id": { "type": "string" },
                "ref_id": { "type": "string" },
                "value_role": { "type": "string", "examples": ["spoken", "shown", "highlighted"] },
                "format_hint": { "type": "string" }
              }
            }
          },

          "character_directive": {
            "type": "object",
            "properties": {
              "emotion": { "type": "string" },
              "gesture": { "type": "string" },
              "move_intent": { "type": "string" },
              "look_at": { "type": "string" },
              "point_at": { "type": "string" }
            }
          },

          "timing_hint": {
            "type": "object",
            "properties": {
              "min_ms": { "type": "integer", "default": 1500 },
              "max_ms": { "type": "integer", "default": 9000 },
              "priority": { "type": "integer", "minimum": 0, "maximum": 10, "default": 5 }
            }
          },

          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
