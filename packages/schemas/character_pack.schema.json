{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "character_pack.schema.json",
  "title": "CharacterPack",
  "type": "object",
  "required": ["schema_version", "pack_id", "meta", "canvas", "assets", "skeleton", "slots", "visemes", "expressions", "clips", "ik_chains"],
  "$defs": {
    "anchor_id": {
      "type": "string",
      "enum": [
        "head_center",
        "mouth_center",
        "eye_near",
        "eye_far",
        "ear_near",
        "ear_far",
        "paw_anchor",
        "tail_root"
      ]
    },
    "anchor_view": {
      "type": "string",
      "enum": ["front", "threeQuarter", "profile"]
    },
    "anchor_entry": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "type": "string", "enum": ["present", "occluded", "missing", "not_applicable"] },
        "notes": { "type": "string" }
      },
      "dependentRequired": {
        "x": ["y"],
        "y": ["x"]
      },
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": { "const": "present" }
            }
          },
          "then": {
            "required": ["x", "y"]
          }
        }
      ],
      "additionalProperties": false
    },
    "anchor_view_manifest": {
      "type": "object",
      "properties": {
        "head_center": { "$ref": "#/$defs/anchor_entry" },
        "mouth_center": { "$ref": "#/$defs/anchor_entry" },
        "eye_near": { "$ref": "#/$defs/anchor_entry" },
        "eye_far": { "$ref": "#/$defs/anchor_entry" },
        "ear_near": { "$ref": "#/$defs/anchor_entry" },
        "ear_far": { "$ref": "#/$defs/anchor_entry" },
        "paw_anchor": { "$ref": "#/$defs/anchor_entry" },
        "tail_root": { "$ref": "#/$defs/anchor_entry" }
      },
      "additionalProperties": false
    },
    "anchor_view_summary": {
      "type": "object",
      "properties": {
        "present_anchor_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/anchor_id" }
        },
        "missing_anchor_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/anchor_id" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "anchor_summary": {
      "type": "object",
      "properties": {
        "covered_views": {
          "type": "array",
          "items": { "$ref": "#/$defs/anchor_view" }
        },
        "missing_views": {
          "type": "array",
          "items": { "$ref": "#/$defs/anchor_view" }
        },
        "by_view": {
          "type": "object",
          "properties": {
            "front": { "$ref": "#/$defs/anchor_view_summary" },
            "threeQuarter": { "$ref": "#/$defs/anchor_view_summary" },
            "profile": { "$ref": "#/$defs/anchor_view_summary" }
          },
          "additionalProperties": false
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "anchor_confidence_summary": {
      "type": "object",
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "by_view": {
          "type": "object",
          "properties": {
            "front": { "type": "number", "minimum": 0, "maximum": 1 },
            "threeQuarter": { "type": "number", "minimum": 0, "maximum": 1 },
            "profile": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "anchor_manifest": {
      "type": "object",
      "properties": {
        "views": {
          "type": "object",
          "properties": {
            "front": { "$ref": "#/$defs/anchor_view_manifest" },
            "threeQuarter": { "$ref": "#/$defs/anchor_view_manifest" },
            "profile": { "$ref": "#/$defs/anchor_view_manifest" }
          },
          "additionalProperties": false
        },
        "summary": { "$ref": "#/$defs/anchor_summary" },
        "confidence_summary": { "$ref": "#/$defs/anchor_confidence_summary" }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "pack_id": { "type": "string" },

    "meta": {
      "type": "object",
      "required": ["name", "created_at"],
      "properties": {
        "name": { "type": "string" },
        "created_at": { "type": "string" },
        "source_image_ref": { "type": "string" },
        "notes": { "type": "string" }
      }
    },

    "canvas": {
      "type": "object",
      "required": ["base_width", "base_height", "coord_space"],
      "properties": {
        "base_width": { "type": "integer", "default": 1024 },
        "base_height": { "type": "integer", "default": 1024 },
        "coord_space": { "type": "string", "enum": ["pixels"], "default": "pixels" }
      }
    },

    "assets": {
      "type": "object",
      "required": ["images"],
      "properties": {
        "images": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },

    "anchors": {
      "description": "Explicit landmark/anchor manifest shared by runtime and QC.",
      "$ref": "#/$defs/anchor_manifest"
    },

    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slot_id", "default_image_id"],
        "properties": {
          "slot_id": { "type": "string" },
          "default_image_id": { "type": "string" },
          "z_index": { "type": "integer", "default": 0 }
        }
      }
    },

    "skeleton": {
      "type": "object",
      "required": ["bones", "attachments"],
      "properties": {
        "bones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["bone_id", "parent_id", "rest"],
            "properties": {
              "bone_id": { "type": "string" },
              "parent_id": { "type": "string" },
              "rest": {
                "type": "object",
                "required": ["x", "y", "rotation_deg"],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "rotation_deg": { "type": "number", "default": 0 }
                }
              },
              "limits": {
                "type": "object",
                "properties": {
                  "min_rotation_deg": { "type": "number" },
                  "max_rotation_deg": { "type": "number" }
                }
              }
            }
          }
        },

        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["slot_id", "image_id", "bone_id", "pivot"],
            "properties": {
              "slot_id": { "type": "string" },
              "image_id": { "type": "string" },
              "bone_id": { "type": "string" },
              "pivot": {
                "type": "object",
                "required": ["px", "py"],
                "properties": {
                  "px": { "type": "number", "minimum": 0, "maximum": 1 },
                  "py": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              },
              "offset": { "type": "object", "properties": { "x": { "type": "number", "default": 0 }, "y": { "type": "number", "default": 0 } } },
              "scale": { "type": "object", "properties": { "x": { "type": "number", "default": 1.0 }, "y": { "type": "number", "default": 1.0 } } },
              "rotation_deg": { "type": "number", "default": 0 }
            }
          }
        }
      }
    },

    "ik_chains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chain_id", "bones", "effector_bone_id", "elbow_hint"],
        "properties": {
          "chain_id": { "type": "string" },
          "bones": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 },
          "effector_bone_id": { "type": "string" },
          "elbow_hint": { "type": "string", "enum": ["up", "down"], "default": "down" },
          "max_stretch": { "type": "number", "default": 1.05 }
        }
      }
    },

    "visemes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["slot_id", "image_id"],
        "properties": {
          "slot_id": { "type": "string", "default": "mouth" },
          "image_id": { "type": "string" }
        }
      }
    },

    "expressions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "slot_overrides": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slot_id", "image_id"],
              "properties": {
                "slot_id": { "type": "string" },
                "image_id": { "type": "string" }
              }
            }
          },
          "bone_overrides": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["bone_id"],
              "properties": {
                "bone_id": { "type": "string" },
                "rotation_deg": { "type": "number" },
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            }
          }
        }
      }
    },

    "clips": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["clip_id", "duration_frames", "tracks"],
        "properties": {
          "clip_id": { "type": "string" },
          "duration_frames": { "type": "integer", "minimum": 1 },
          "tracks": {
            "type": "object",
            "properties": {
              "bone_tracks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["bone_id", "keys"],
                  "properties": {
                    "bone_id": { "type": "string" },
                    "keys": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["f"],
                        "properties": {
                          "f": { "type": "integer", "minimum": 0 },
                          "rotation_deg": { "type": "number" },
                          "x": { "type": "number" },
                          "y": { "type": "number" },
                          "sx": { "type": "number" },
                          "sy": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              },
              "slot_swap_tracks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["slot_id", "keys"],
                  "properties": {
                    "slot_id": { "type": "string" },
                    "keys": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["f", "image_id"],
                        "properties": {
                          "f": { "type": "integer", "minimum": 0 },
                          "image_id": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
