generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EpisodeStatus {
  DRAFT
  GENERATING
  PREVIEW_READY
  APPROVED
  RENDERING
  COMPLETED
  FAILED
}

enum JobType {
  GENERATE_SCRIPT
  GENERATE_CHARACTER_ASSETS
  GENERATE_BEATS
  COMPILE_SHOTS
  ASSET_INGEST
  BUILD_CHARACTER_PACK
  RENDER_CHARACTER_PREVIEW
  FETCH_DATA
  RENDER_PREVIEW
  RUN_QC
  RENDER_FINAL
  GENERATE_METADATA
  PACKAGE_OUTPUTS
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum RenderKind {
  PREVIEW
  FINAL
}

enum RenderStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum AssetType {
  JSON
  VIDEO
  AUDIO
  IMAGE
  SUBTITLE
  LOG
}

enum AssetIngestType {
  CHARACTER_REFERENCE
  CHARACTER_VIEW
  BACKGROUND
  CHART_SOURCE
}

enum AssetIngestStatus {
  UPLOADED
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum QCSeverity {
  INFO
  WARN
  ERROR
}

enum QCCheck {
  SCHEMA
  ASSET_MISSING
  NUMBER_MISMATCH
  POINTING_FAIL
  TEXT_OVERFLOW
  AUDIO_CLIP
}

enum CharacterPackStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

enum SlotStatus {
  OPEN
  SCHEDULED
  SKIPPED
}

enum BacklogStatus {
  PENDING
  SCHEDULED
  COMPLETED
  ARCHIVED
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  ARCHIVED
}

enum AgentSuggestionType {
  DIRECTOR
  QA_INSPECTOR
  TEMPLATE_IMPROVER
  HITL_REVIEW
}

enum AgentSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  channels Channel[]
}

model Channel {
  id        String   @id @default(cuid())
  userId    String
  name      String
  language  String   @default("ko-KR")
  timezone  String   @default("Asia/Seoul")
  createdAt DateTime @default(now())

  user         User            @relation(fields: [userId], references: [id])
  bibles       ChannelBible[]
  episodes     Episode[]
  assets       Asset[]
  datasets     Dataset[]
  characters   CharacterPack[]
  seasons      Season[]
  backlogItems BacklogItem[]
  metrics      Metric[]
  experiments  Experiment[]

  @@index([userId])
}

model Season {
  id              String   @id @default(cuid())
  channelId       String
  name            String
  startDate       DateTime
  endDate         DateTime
  episodesPerWeek Int      @default(3)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  channel      Channel        @relation(fields: [channelId], references: [id])
  slots        CalendarSlot[]
  backlogItems BacklogItem[]
  episodes     Episode[]

  @@index([channelId, isActive])
  @@index([channelId, startDate, endDate])
}

model CalendarSlot {
  id            String     @id @default(cuid())
  seasonId      String
  scheduledDate DateTime
  status        SlotStatus @default(OPEN)
  backlogItemId String?
  episodeId     String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  season      Season       @relation(fields: [seasonId], references: [id])
  backlogItem BacklogItem? @relation(fields: [backlogItemId], references: [id])
  episode     Episode?     @relation(fields: [episodeId], references: [id])

  @@unique([seasonId, scheduledDate])
  @@index([seasonId, status])
}

model BacklogItem {
  id          String        @id @default(cuid())
  channelId   String
  seasonId    String?
  title       String
  description String?
  priority    Int           @default(0)
  status      BacklogStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  channel Channel        @relation(fields: [channelId], references: [id])
  season  Season?        @relation(fields: [seasonId], references: [id])
  episode Episode?       @relation("BacklogEpisode")
  slots   CalendarSlot[]

  @@index([channelId, status, priority])
  @@index([seasonId, status])
}

model Metric {
  id          String   @id @default(cuid())
  channelId   String
  key         String
  displayName String?
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel        Channel         @relation(fields: [channelId], references: [id])
  episodeMetrics EpisodeMetric[]

  @@unique([channelId, key])
  @@index([channelId])
}

model Experiment {
  id          String           @id @default(cuid())
  channelId   String
  name        String
  description String?
  status      ExperimentStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  channel        Channel             @relation(fields: [channelId], references: [id])
  variants       ExperimentVariant[]
  episodeMetrics EpisodeMetric[]

  @@index([channelId, status])
  @@index([channelId, startDate, endDate])
}

model ExperimentVariant {
  id           String   @id @default(cuid())
  experimentId String
  key          String
  name         String
  weight       Int      @default(50)
  isControl    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  experiment     Experiment      @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  episodeMetrics EpisodeMetric[]

  @@unique([experimentId, key])
  @@index([experimentId])
}

model ChannelBible {
  id        String   @id @default(cuid())
  channelId String
  version   Int
  hash      String   @unique
  schemaId  String   @default("channel_bible.schema.json")
  json      Json
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel  Channel   @relation(fields: [channelId], references: [id])
  episodes Episode[]

  @@index([channelId, version])
  @@index([channelId, isActive])
}

model CharacterPack {
  id        String              @id @default(cuid())
  channelId String
  version   Int
  hash      String              @unique
  status    CharacterPackStatus @default(DRAFT)
  schemaId  String              @default("character_pack.schema.json")
  json      Json
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  channel  Channel   @relation(fields: [channelId], references: [id])
  episodes Episode[]

  @@index([channelId, version])
  @@index([channelId, status])
}

model Dataset {
  id          String   @id @default(cuid())
  channelId   String
  name        String
  provider    String?
  description String?
  createdAt   DateTime @default(now())

  channel  Channel          @relation(fields: [channelId], references: [id])
  versions DatasetVersion[]

  @@unique([channelId, name])
  @@index([channelId])
}

model DatasetVersion {
  id        String   @id @default(cuid())
  datasetId String
  version   Int
  sourceUrl String?
  sha256    String?
  meta      Json?
  createdAt DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id])

  @@unique([datasetId, version])
  @@index([datasetId])
}

model Episode {
  id                String        @id @default(cuid())
  channelId         String
  topic             String
  status            EpisodeStatus @default(DRAFT)
  targetDurationSec Int           @default(600)

  bibleId                String?
  characterPackId        String?
  seasonId               String?
  backlogItemId          String?   @unique
  scheduledFor           DateTime?
  templateVersion        String    @default("mvp1")
  characterPackVersion   Int?
  datasetVersionSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel       Channel        @relation(fields: [channelId], references: [id])
  bible         ChannelBible?  @relation(fields: [bibleId], references: [id])
  characterPack CharacterPack? @relation(fields: [characterPackId], references: [id])
  season        Season?        @relation(fields: [seasonId], references: [id])
  backlogItem   BacklogItem?   @relation("BacklogEpisode", fields: [backlogItemId], references: [id])
  slot          CalendarSlot?

  beatsDoc       BeatDoc?
  shotsDoc       ShotDoc?
  renders        Render[]
  jobs           Job[]
  qcResults      QCResult[]
  episodeMetrics EpisodeMetric[]
  agentSuggestions AgentSuggestion[]

  @@index([channelId])
  @@index([status])
  @@index([seasonId])
  @@index([scheduledFor])
  @@index([templateVersion])
}

model EpisodeMetric {
  id           String   @id @default(cuid())
  episodeId    String
  metricId     String
  value        Float
  observedAt   DateTime
  source       String   @default("manual")
  ingestionId  String   @unique
  experimentId String?
  variantId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  episode    Episode            @relation(fields: [episodeId], references: [id])
  metric     Metric             @relation(fields: [metricId], references: [id])
  experiment Experiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variant    ExperimentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([episodeId, observedAt])
  @@index([metricId, observedAt])
  @@index([experimentId, variantId])
}

model BeatDoc {
  id        String   @id @default(cuid())
  episodeId String   @unique
  schemaId  String   @default("beats.schema.json")
  json      Json
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id])
}

model ShotDoc {
  id        String   @id @default(cuid())
  episodeId String   @unique
  schemaId  String   @default("shots.schema.json")
  json      Json
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id])
}

model Render {
  id            String       @id @default(cuid())
  episodeId     String
  kind          RenderKind
  status        RenderStatus @default(QUEUED)
  attempt       Int          @default(1)
  startedAt     DateTime?
  finishedAt    DateTime?
  outputAssetId String?

  episode Episode @relation(fields: [episodeId], references: [id])

  outputAsset Asset? @relation("RenderOutputAsset", fields: [outputAssetId], references: [id])

  qcResults QCResult[]

  @@index([episodeId, kind])
  @@index([status])
}

model Asset {
  id          String    @id @default(cuid())
  channelId   String
  type        AssetType
  assetType   AssetIngestType?
  status      AssetIngestStatus @default(READY)
  mime        String?
  sizeBytes   BigInt?
  storageKey  String    @unique
  originalKey String?
  normalizedKey1024 String?
  normalizedKey2048 String?
  qcJson      Json?
  contentType String?
  bytes       BigInt?
  sha256      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  channel Channel @relation(fields: [channelId], references: [id])

  rendersAsOutput Render[] @relation("RenderOutputAsset")

  @@index([channelId, type])
  @@index([status])
  @@index([assetType, status])
}

model QCResult {
  id        String     @id @default(cuid())
  episodeId String?
  renderId  String?
  check     QCCheck
  severity  QCSeverity
  passed    Boolean
  details   Json?
  createdAt DateTime   @default(now())

  episode Episode? @relation(fields: [episodeId], references: [id])
  render  Render?  @relation(fields: [renderId], references: [id])

  @@index([episodeId])
  @@index([renderId])
  @@index([check, severity])
}

model Job {
  id                     String    @id @default(cuid())
  episodeId              String
  type                   JobType
  status                 JobStatus @default(QUEUED)
  progress               Int       @default(0)
  attemptsMade           Int       @default(0)
  maxAttempts            Int       @default(2)
  bullmqJobId            String?   @unique
  lastError              String?
  retryBackoffMs         Int       @default(1000)
  estimatedRenderSeconds Int       @default(0)
  estimatedAudioSeconds  Int       @default(0)
  estimatedApiCalls      Int       @default(0)
  estimatedCostUsd       Float     @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  episode Episode  @relation(fields: [episodeId], references: [id])
  logs    JobLog[]
  agentSuggestions AgentSuggestion[]

  @@index([episodeId, type])
  @@index([status])
}

model AgentSuggestion {
  id        String                @id @default(cuid())
  episodeId String?
  jobId     String?
  type      AgentSuggestionType
  status    AgentSuggestionStatus @default(PENDING)
  title     String
  summary   String?
  payload   Json
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  job     Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([episodeId, type, createdAt])
  @@index([status, createdAt])
  @@index([jobId])
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String   @default("info")
  message   String
  details   Json?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model AuditLog {
  id              String   @id @default(cuid())
  method          String
  path            String
  statusCode      Int
  success         Boolean  @default(true)
  actorApiKeyHash String?
  clientIp        String?
  userAgent       String?
  requestId       String?
  details         Json?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([statusCode, createdAt])
}
