{
  "name": "@ec/db",
  "private": true,
  "scripts": {
    "prisma": "dotenv -e ../../.env -o -- prisma",
    "generate": "dotenv -e ../../.env -o -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env -o -- prisma migrate dev && dotenv -e ../../.env -o -- prisma generate",
    "migrate:deploy": "node ./scripts/migrateDeployWithRetry.mjs",
    "studio": "dotenv -e ../../.env -o -- prisma studio",
    "format": "dotenv -e ../../.env -o -- prisma format"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0"
  }
}
