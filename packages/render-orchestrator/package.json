{
  "name": "@ec/render-orchestrator",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "render:demo": "pnpm exec tsx src/renderDemo.ts",
    "render:smoke": "pnpm exec tsx src/renderDemo.ts --dry-run",
    "render:smoke:profiles": "pnpm exec tsx src/profileBundleSmoke.ts",
    "render:smoke:profiles-package": "pnpm exec tsx src/renderDemo.ts --dry-run --profile-resolver-module ./src/fixtures/profileResolverModule.stub.ts",
    "render:smoke:profiles-auto-discovery": "pnpm exec tsx src/renderDemo.ts --dry-run --profile-resolver-module auto",
    "render:probe:profile-resolver": "pnpm exec tsx src/profileResolverProbe.ts"
  },
  "dependencies": {
    "@ec/shared": "workspace:*",
    "@ec/story": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
