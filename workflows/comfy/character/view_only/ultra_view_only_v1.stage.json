        "canny": { "min": 0, "max": 0.08 }
      },
      "threeQuarter": {
        "lineart": { "min": 0, "max": 0.08 },
        "canny": { "min": 0, "max": 0.08 }
      },
      "profile": {
        "lineart": { "min": 0, "max": 0.08 },
        "canny": { "min": 0, "max": 0.08 }
      }
    },
    "end_percent_range_by_kind_by_view": {
      "front": {
        "lineart": { "min": 0.72, "max": 0.9 },
        "canny": { "min": 0.64, "max": 0.82 }
      },
      "threeQuarter": {
        "lineart": { "min": 0.76, "max": 0.9 },
        "canny": { "min": 0.7, "max": 0.84 }
      },
      "profile": {
        "lineart": { "min": 0.76, "max": 0.9 },
        "canny": { "min": 0.7, "max": 0.84 }
      }
    },
    "min_schedule_span_by_kind_by_view": {
      "front": {
        "lineart": 0.62,
        "canny": 0.54
      },
      "threeQuarter": {
        "lineart": 0.68,
        "canny": 0.62
      },
      "profile": {
        "lineart": 0.68,
        "canny": 0.62
      }
    },
    "allowed_source_roles_by_kind_by_view": {
      "front": {
        "lineart": ["front_master", "subject", "starter"],
        "canny": ["front_master", "subject", "starter", "composition"]
      },
      "threeQuarter": {
        "lineart": ["composition"],
        "canny": ["composition"]
      },
      "profile": {
        "lineart": ["composition"],
        "canny": ["composition"]
      }
    },
    "required_primary_source_role_by_kind_by_view": {
      "front": {
        "lineart": "front_master",
        "canny": "front_master"
      },
      "threeQuarter": {
        "lineart": "composition",
        "canny": "composition"
      },
      "profile": {
        "lineart": "composition",
        "canny": "composition"
      }
    },
    "require_view_match_for_source_roles": ["composition", "repair_base"],
    "disallowed_source_roles": ["style", "repair_base"]
  },
  "control_stack": {
    "required_nodes": [
      "CheckpointLoaderSimple",
      "CLIPTextEncode",
      "IPAdapterUnifiedLoader",
      "IPAdapterAdvanced",
      "KSampler",
      "VAEDecode",
      "SaveImage"
    ],
    "optional_nodes": [
      "IPAdapterPreciseStyleTransfer",
      "IPAdapterPreciseComposition",
      "OpenposePreprocessor",
      "ControlNetLoader",
      "ControlNetApplyAdvanced",
      "CannyEdgePreprocessor",
      "Canny",
      "LineArtPreprocessor",
      "LatentUpscaleBy",
      "LatentUpscale"
    ]
  },
  "output_contract": {
    "approved_views": ["front", "threeQuarter", "profile"],
    "expected_artifacts": ["*_workflow_api.json", "*_workflow_gui.json", "*_workflow_summary.json"]
  }
