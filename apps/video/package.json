    "render:cinematic-turn": "remotion render src/index.ts CINEMATIC-TURN-DEMO ../../out/cinematic-turn-demo.mp4 --overwrite",
    "render:character-pack-preview": "remotion render src/index.ts CHARACTER-PACK-PREVIEW ../../out/character-pack-preview.mp4 --overwrite",
    "render:anim-smoke": "remotion render src/index.ts ANIM-TOOLKIT-SMOKE ../../out/anim-toolkit-smoke.mp4 --overwrite",
    "render:camera-showcase": "remotion render src/index.ts CAMERA-SHOWCASE ../../out/camera-showcase.mp4 --overwrite",
    "render:motion-fx": "remotion render src/index.ts MOTION-FX-SHOWCASE ../../out/motion-fx-showcase.mp4 --overwrite",
    "render:character-life": "remotion render src/index.ts CHARACTER-LIFE-DEMO ../../out/character-life-demo.mp4 --overwrite",
    "render:talk-demo": "remotion render src/index.ts TALK-DEMO ../../out/talk-demo.mp4 --overwrite",
