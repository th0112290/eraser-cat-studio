{
  "name": "@ec/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json --noEmit",
    "dev": "dotenv -e ../../.env -o -- tsx src/dev.ts",
    "enqueue:test": "dotenv -e ../../.env -o -- tsx src/enqueueTest.ts",
    "enqueue:render:test": "dotenv -e ../../.env -o -- tsx src/enqueueRenderTest.ts",
    "smoke:env": "dotenv -e ../../.env -o -- node -e \"if(!process.env.DATABASE_URL||!process.env.REDIS_URL){throw new Error('Missing DATABASE_URL/REDIS_URL')} console.log('[worker] env smoke ok')\"",
    "smoke:persistence": "dotenv -e ../../.env -o -- tsx src/smokeJobPersistence.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@ec/audio": "workspace:*",
    "@ec/ops": "workspace:*",
    "@ec/publish": "workspace:*",
    "@ec/render-orchestrator": "workspace:*",
    "@ec/shared": "workspace:*",
    "@ec/story": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "sharp": "^0.34.2",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.8.3"
  }
}
