{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@ec/analytics": ["../../packages/analytics/src/index.ts"],
      "@ec/image-gen": ["../../packages/image-gen/src/index.ts"],
      "@ec/ops": ["../../packages/ops/src/index.ts"],
      "@ec/publish": ["../../packages/publish/src/index.ts"],
      "@ec/shared": ["../../packages/shared/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
