{
  "name": "eraser-cat-studio",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "smoke:preview": "pnpm -C apps/video run qc:smoke",
    "smoke:action-overrides": "pnpm -C apps/video run smoke:action-overrides",
    "smoke:e2e": "node scripts/smokeE2E.mjs",
    "smoke:e2e:pipeline": "node scripts/smokePipeline.mjs",
    "smoke:e2e:pipeline:full": "node scripts/smokePipeline.mjs --target=full",
    "smoke:e2e:overrides": "node scripts/smokeActionOverrides.mjs",
    "smoke:e2e:split": "node scripts/smokeSplit.mjs",
    "ci:checks:capture": "node scripts/capturePrCheckNames.mjs",
    "ci:checks:verify": "node scripts/capturePrCheckNames.mjs --strict-required",
    "worktree:status": "node scripts/worktreeStatus.mjs",
    "smoke:character": "node scripts/smokeCharacter.mjs",
    "smoke:mascot-family": "node scripts/smokeMascotFamily.mjs",
    "smoke:auto-reroute": "pnpm -C apps/worker run smoke:auto-reroute",
    "smoke:side-view-gate": "pnpm -C apps/worker run smoke:side-view-gate",
    "smoke:stage-input-preflight": "pnpm -C apps/worker run smoke:stage-input-preflight",
    "smoke:repair-triage-gate": "pnpm -C apps/worker run smoke:repair-triage-gate",
    "smoke:post-repair-acceptance-gate": "pnpm -C apps/worker run smoke:post-repair-acceptance-gate",
    "smoke:selection-firewall": "pnpm -C apps/worker run smoke:selection-firewall",
    "smoke:character:strict": "node --input-type=module -e \"process.env.SMOKE_REQUIRE_CONTINUITY='1'; await import('./scripts/smokeCharacter.mjs');\"",
    "smoke:character:hitl": "node scripts/smokeCharacter.mjs",
    "selftest:comfy-stage-contract": "node scripts/comfyStageContractSelftest.mjs",
    "selftest:comfy-adapter-fake-smoke": "node scripts/comfyAdapterFakeSmoke.mjs",
    "smoke:video-broll": "pnpm -C apps/worker run smoke:video-broll",
    "benchmark:motion-presets": "pnpm -C apps/video run benchmark:motion-presets",
    "validate:motion-preset-benchmark": "pnpm -C apps/worker run validate:motion-preset-benchmark",
    "smoke:motion-policy": "node scripts/runMotionPolicySmoke.mjs",
    "rollout:video-i2v-preset": "node scripts/runVideoI2vPresetRollout.mjs",
    "rollout:video-i2v-multichannel": "node scripts/runVideoI2vMultiChannelRollout.mjs",
    "plan:video-i2v-preset-convergence": "pnpm -C apps/worker run plan:video-i2v-preset-convergence",
    "report:shot-render-modes": "node scripts/reportShotRenderModes.mjs",
    "smoke:ui": "node scripts/smokeUiRoutes.mjs",
    "smoke:ui:down": "node scripts/smokeUiRoutes.mjs",
    "smoke:ui:up": "node --input-type=module -e \"process.env.SMOKE_DB_MODE='up'; await import('./scripts/smokeUiRoutes.mjs');\"",
    "smoke:ui:capture": "node scripts/captureUiSnapshots.mjs",
    "smoke:ui:visual": "node scripts/smokeUiVisualContract.mjs",
    "smoke:ui:capture": "node scripts/captureUiSnapshots.mjs",
    "comfy:adapter": "node scripts/comfyAdapter.mjs",
    "comfy:preflight": "node scripts/comfyPreflight.mjs",
    "comfy:download:text-encoders": "node scripts/comfyDownloadFluxTextEncoders.mjs",
    "comfy:preflight:video": "node scripts/comfyVideoPreflight.mjs",
    "comfy:stop:local": "powershell -ExecutionPolicy Bypass -File scripts/stopLocalComfyUI.ps1",
    "comfy:download:video-broll": "node scripts/comfyDownloadWanVideoModels.mjs",
    "dev:down": "docker compose -f docker/docker-compose.yml down",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "smoke:docker": "node -e \"const {execSync}=require('node:child_process');try{execSync('docker version',{stdio:'inherit'});console.log('[smoke:docker] Docker daemon is reachable.');}catch(error){console.error('[smoke:docker] Docker daemon is unreachable. Start Docker Desktop, wait until it is running, then retry.');console.error('[smoke:docker] Next steps: docker version -> pnpm docker:up');process.exit(1);}\"",

    "db:migrate": "node scripts/dbMigrate.mjs",
    "db:status": "pnpm -C packages/db prisma migrate status",
    "db:studio": "pnpm -C packages/db studio",
    "db:generate": "pnpm -C packages/db generate",

    "api:dev": "pnpm -C apps/api dev",
    "worker:dev": "pnpm -C apps/worker dev",
    "api:up": "powershell -ExecutionPolicy Bypass -File scripts/startApi.ps1",
    "api:down": "powershell -ExecutionPolicy Bypass -File scripts/startApi.ps1 -Stop",
    "worker:up": "powershell -ExecutionPolicy Bypass -File scripts/startWorker.ps1",
    "worker:down": "powershell -ExecutionPolicy Bypass -File scripts/startWorker.ps1 -Stop"
  }
}
