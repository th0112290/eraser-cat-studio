{
  "name": "eraser-cat-studio",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "smoke:preview": "pnpm -C apps/video run qc:smoke",
    "smoke:action-overrides": "pnpm -C apps/video run smoke:action-overrides",
    "smoke:e2e": "node scripts/smokeE2E.mjs",
    "smoke:e2e:pipeline": "node scripts/smokePipeline.mjs",
    "smoke:e2e:pipeline:full": "node scripts/smokePipeline.mjs --target=full",
    "smoke:e2e:overrides": "node scripts/smokeActionOverrides.mjs",
    "smoke:e2e:split": "node scripts/smokeSplit.mjs",
    "ci:checks:capture": "node scripts/capturePrCheckNames.mjs",
    "ci:checks:verify": "node scripts/capturePrCheckNames.mjs --strict-required",
    "smoke:character": "node scripts/smokeCharacter.mjs",
    "smoke:character:strict": "node --input-type=module -e \"process.env.SMOKE_REQUIRE_CONTINUITY='1'; await import('./scripts/smokeCharacter.mjs');\"",
    "smoke:character:hitl": "node scripts/smokeCharacter.mjs",
    "smoke:ui": "node scripts/smokeUiRoutes.mjs",
    "smoke:ui:down": "node scripts/smokeUiRoutes.mjs",
    "smoke:ui:up": "node --input-type=module -e \"process.env.SMOKE_DB_MODE='up'; await import('./scripts/smokeUiRoutes.mjs');\"",
    "smoke:ui:visual": "node scripts/smokeUiVisualContract.mjs",
    "dev:down": "docker compose -f docker/docker-compose.yml down",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "smoke:docker": "node -e \"const {execSync}=require('node:child_process');try{execSync('docker version',{stdio:'inherit'});console.log('[smoke:docker] Docker daemon is reachable.');}catch(error){console.error('[smoke:docker] Docker daemon is unreachable. Start Docker Desktop, wait until it is running, then retry.');console.error('[smoke:docker] Next steps: docker version -> pnpm docker:up');process.exit(1);}\"",

    "db:migrate": "pnpm -C packages/db migrate:dev && pnpm -C packages/db generate",
    "db:status": "pnpm -C packages/db prisma migrate status",
    "db:studio": "pnpm -C packages/db studio",
    "db:generate": "pnpm -C packages/db generate",

    "api:dev": "pnpm -C apps/api dev",
    "worker:dev": "pnpm -C apps/worker dev"
  }
}
